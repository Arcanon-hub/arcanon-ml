# --- Mandatory Secrets ---
HF_TOKEN=your_huggingface_token_here
WANDB_API_KEY=your_wandb_key_if_using

# --- Pipeline Control (true/false) ---
RUN_PHASE_1=false
RUN_PHASE_2=false
RUN_EXPORT=false
PUSH_ONNX=false
SKIP_CHECK=false

# --- Reporting ---
# Set to "wandb" to enable monitoring, "none" to disable
REPORT_TO=none

# --- Hugging Face Repositories ---
# Use your-username/repo-name format
HF_REPO_MLM=your-username/arcanon-codebert-mlm
HF_REPO_CLASSIFIER=your-username/arcanon-codebert-classifier
HF_REPO_ONNX=your-username/arcanon-codebert-onnx
